{
  "plugins": [
    "plugins/markdown",
    "node_modules/better-docs/category"
  ],
  "recurseDepth": 10,
  "source": {
    "include": ["src"],
    "includePattern": ".+\\.jsx?$",
    "excludePattern": "node_modules|\\.(test|spec)\\.js$"
  },
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc"]
  },
  "templates": {
    "better-docs": {
        "name": "My Planner Documentation",
        "title": "My Planner API",
        "css": "hide",
        "hideGenerator": false
    }
  },
  "opts": {
    "template": "node_modules/better-docs",
    "encoding": "utf8",
    "destination": "docs/api/",
    "recurse": true,
    "readme": "README.md"
  }
}
